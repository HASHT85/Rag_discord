# === Discord Bot ===
DISCORD_TOKEN=votre_token_discord_ici

# === OpenRouter (LLM + Embeddings) ===
OPENROUTER_API_KEY=votre_cle_openrouter_ici

# Modèle LLM pour la génération de réponses
LLM_MODEL=google/gemini-3.1-flash-lite

# Modèle d'embedding pour la vectorisation
EMBEDDING_MODEL=google/gemini-embedding-2-preview

# === ChromaDB ===
CHROMA_PERSIST_DIR=./chroma_db

# === RAG Parameters ===
# Nombre de résultats retournés par la recherche de similarité
TOP_K=5

# Taille maximale des chunks (en caractères)
CHUNK_SIZE=500

# Chevauchement entre les chunks
CHUNK_OVERLAP=50
